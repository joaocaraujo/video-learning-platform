{
  "name": "video-learning-platform",
  "version": "1.0.0",
  "description": "Plataforma local de aprendizagem que transforma diretórios de vídeos em cursos estruturados",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && npm run build:renderer",
    "build:renderer": "vite build",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite",
    "start": "npm run build && electron .",
    "watch:main": "tsc -p tsconfig.main.json --watch"
  },
  "keywords": [
    "learning",
    "video",
    "courses",
    "offline"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "media-chrome": "^4.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
